# ADVantage Insights Brain Encoder — Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Your Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OPTIONAL: Access password to restrict who can use the platform
# Leave empty for open access
ACCESS_PASSWORD=

# OPTIONAL: Custom branding
VITE_BRAND_NAME=ADVantage Insights
VITE_PLATFORM_NAME=Brain Encoder
